# ══════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DEL PROYECTO ATTENDANCE-FACIAL
# ══════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env y llena los valores reales

# ── SUPABASE (Base de datos principal) ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT (Autenticación) ───────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
# JWT_ALGORITHM=HS256 (Por defecto en config.py)
# JWT_EXPIRATION_HOURS=24 (Por defecto en config.py)

# ── EMAIL (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=InClass <noreply@yourdomain.com>

# ── FIREBASE (Notificaciones push) ────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=path/to/firebase-credentials.json

# ── PINECONE (Base de datos vectorial) ────────────────────────────────────
# Deja en blanco para usar pickle (desarrollo)
# Completa estos campos para producción
USE_PINECONE=false
PINECONE_API_KEY=
PINECONE_ENV=gcp-starter
# PINECONE_INDEX_NAME=facial-recognition (Por defecto en config.py)
# PINECONE_DIMENSION=512 (Por defecto en config.py)

# ── LOGGING ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Opciones: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ══════════════════════════════════════════════════════════════════════════
# NOTAS DE SEGURIDAD:
# ══════════════════════════════════════════════════════════════════════════
# 1. NUNCA commitees .env a git
# 2. Usa valores diferentes entre desarrollo y producción
# 3. JWT_SECRET debe ser una cadena fuerte y aleatoria
# 4. Protege tus API keys de Supabase y Pinecone
# 5. En producción, usa variables de entorno en tu servidor/plataforma
#    (AWS Secrets Manager, Google Cloud Secret Manager, etc.)
